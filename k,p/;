берем первый элемент и считаем его за максимум
поочередно перебираем элементы массива со второго по последний
    если элемент массива больще максимума
        максимумом становиться элемент этого массива
        сохраняем его индекс
напечатать максимум и его индекс, минимум и его индекс


import random

s = []
for i in range(15):
    s.append(random.randint(-20, 30))

print("Сгенерированный массив:", s)

min_s = s[0]
min_indx = 0
for i in range(1, len(s)):
    if s[i] < min_s:
        min_s = s[i]
        min_indx = i

max_s = s[0]
max_indx = 0
for i in range(1, len(s)):
    if s[i] > max_s:
        max_s = s[i]
        max_indx = i

print("Минимальный элемент:", min_s, "на индексе", min_indx)
print("Максимальный элемент:", max_s, "на индексе", max_indx)





повтор 10 раз 
    добавить в массив случайный элемент от 1 до 50
напечатать массив
повтор 10 раз
    если колво повторений цикла четно
        добавить в список с индексом колва повторений цикла элемент массива умноженный на 2
    иначе
        добавить в список с индексом колва повторений цикла элемент массива нацело деленный на 2

import random

s = []
for i in range(10):
    s.append(random.randint(1, 50))

print("Исходный массив:", s)

new_s = []
for i in range(10):
    if i % 2 == 0:
        new_s.append(s[i] * 2)
    else:
        new_s.append(s[i] // 2)

print("Новый массив:   ", new_s)

